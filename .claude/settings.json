{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm install)",
      "Bash(pnpm install:*)",
      "Bash(pnpm webkit:lint)",
      "Bash(pnpm webkit:lint:*)",
      "Bash(pnpm webkit:type-check)",
      "Bash(pnpm webkit:type-coverage)",
      "Bash(pnpm webkit:format)",
      "Bash(pnpm webkit:format:check)",
      "Bash(pnpm storybook:build)",
      "Bash(pnpm storybook:dev)",
      "Bash(pnpm storybook:preview)",
      "Bash(pnpm icons:build)",
      "Bash(pnpm icons:validate)",
      "Bash(pnpm governance)",
      "Bash(pnpm --filter:*)",
      "Bash(npx prettier:*)",
      "Bash(npx eslint:*)",
      "Bash(npx stylelint:*)",
      "Bash(npx vue-tsc:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(npm run *)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(rm -rf:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/validate-tokens.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/validate-references.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/validate-story-source.mjs"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/enforce-component-create.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/enforce-spec-exists.mjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/validate-spec-compliance.mjs"
          }
        ]
      }
    ]
  }
}
