{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aziontech.github.io/webkit/.specs/_schema.json",
  "title": "Webkit Component Spec — frontmatter",
  "description": "Schema for the YAML frontmatter of every .specs/<name>.md. Body sections (Props/Events/Slots/...) are validated separately by .claude/hooks/_lib/spec.mjs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "category",
    "structure",
    "status",
    "spec_version",
    "created",
    "last_updated"
  ],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$",
      "description": "Component name in kebab-case."
    },
    "category": {
      "type": "string",
      "enum": [
        "actions",
        "content",
        "data",
        "feedback",
        "inputs",
        "layout",
        "navigation",
        "overlay",
        "utils"
      ]
    },
    "structure": {
      "type": "string",
      "enum": ["monolithic", "composition"]
    },
    "status": {
      "type": "string",
      "enum": ["draft", "approved", "implemented", "locked"]
    },
    "spec_version": {
      "type": "integer",
      "minimum": 1
    },
    "figma": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url"],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://(www\\.)?figma\\.com/"
        },
        "node_id": {
          "type": "string",
          "pattern": "^[0-9]+[:-][0-9]+$"
        }
      }
    },
    "checksum": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "sha256 of the spec body (everything after the frontmatter). Written by spec-validator on approval; verified by enforce-spec-exists on every Write."
    },
    "created": {
      "type": "string",
      "format": "date"
    },
    "last_updated": {
      "type": "string",
      "format": "date"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "status": { "enum": ["approved", "implemented", "locked"] } },
        "required": ["status"]
      },
      "then": {
        "required": ["checksum"],
        "description": "Once a spec is approved or beyond, the checksum field is mandatory and must match sha256(body)."
      }
    }
  ]
}
