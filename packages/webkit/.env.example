# Copy this file to `.env` (gitignored) and fill the values locally.
# Never commit a real token.

# Figma Code Connect — personal access token used by `pnpm --filter webkit run figma:publish`.
# Generate at https://www.figma.com/developers/api#access-tokens
# Required scopes: File content (read), Code Connect (write).
# Org plan: Code Connect needs a Dev Mode seat + Code Connect feature enabled on the org.
FIGMA_ACCESS_TOKEN=
