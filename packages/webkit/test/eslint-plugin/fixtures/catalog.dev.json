{
  "package": "@aziontech/webkit.dev",
  "webkitVersion": "9.9.9",
  "deniedPrefixes": ["@aziontech/webkit.dev/src/"],
  "tokenRules": [
    {
      "id": "hex-color",
      "pattern": "#[0-9a-fA-F]{3,8}\\b",
      "flags": "g",
      "message": "Hex color hardcoded. Use semantic tokens (var(--primary), ...)."
    },
    {
      "id": "tailwind-palette",
      "pattern": "\\b(?:bg|text|border)-(?:gray|red|blue|green)-\\d{2,3}\\b",
      "flags": "g",
      "message": "Tailwind palette color. Use semantic webkit tokens."
    }
  ],
  "imports": {
    "button": {
      "import": "@aziontech/webkit.dev/button",
      "kind": "component",
      "treeShakeableImport": "@aziontech/webkit.dev/button"
    },
    "card-box": {
      "import": "@aziontech/webkit.dev/card-box",
      "kind": "component",
      "treeShakeableImport": "@aziontech/webkit.dev/card-box"
    },
    "chip": {
      "import": "@aziontech/webkit.dev/chip",
      "kind": "component",
      "treeShakeableImport": "@aziontech/webkit.dev/chip"
    },
    "chips": {
      "import": "@aziontech/webkit.dev/chips",
      "kind": "component",
      "treeShakeableImport": "@aziontech/webkit.dev/chips"
    },
    "table": {
      "import": "@aziontech/webkit.dev/table",
      "kind": "component",
      "compoundRoot": true,
      "treeShakeableImport": "@aziontech/webkit.dev/table-root",
      "subcomponents": ["@aziontech/webkit/table-row"]
    },
    "table-root": {
      "import": "@aziontech/webkit.dev/table-root",
      "kind": "root",
      "rootOf": "table",
      "treeShakeableImport": "@aziontech/webkit.dev/table-root"
    },
    "table-row": {
      "import": "@aziontech/webkit.dev/table-row",
      "kind": "subcomponent",
      "parent": "table",
      "treeShakeableImport": "@aziontech/webkit.dev/table-row"
    }
  }
}
